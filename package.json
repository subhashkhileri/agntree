{
  "name": "claude-workspaces",
  "displayName": "Claude Workspaces",
  "description": "Manage Claude Code sessions across repositories and worktrees",
  "version": "0.1.0",
  "publisher": "claude-workspaces",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claude-workspaces",
          "title": "Claude Workspaces",
          "icon": "resources/icons/claude.svg"
        }
      ]
    },
    "views": {
      "claude-workspaces": [
        {
          "id": "workspacesView",
          "name": "Workspaces"
        },
        {
          "id": "changesView",
          "name": "Changes"
        },
        {
          "id": "quickActionsView",
          "name": "Quick Actions"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "workspacesView",
        "contents": "Start managing your Claude Code sessions across repositories.\n\n[Add Local Repository](command:claude-workspaces.addRepository)\n[Clone from GitHub](command:claude-workspaces.cloneRepository)\n\nAdd an existing git repository or clone one from GitHub to get started."
      },
      {
        "view": "changesView",
        "contents": "Select a worktree or session to view uncommitted changes.\n\nClick the diff icon on any file to view side-by-side comparison."
      },
      {
        "view": "quickActionsView",
        "contents": "Run Claude prompts or shell commands.\n\n[Add Quick Action](command:claude-workspaces.addQuickAction)\n\nConfigure actions in Settings → claude-workspaces.quickActions"
      }
    ],
    "commands": [
      {
        "command": "claude-workspaces.addRepository",
        "title": "Add Local Repository",
        "icon": "$(folder)"
      },
      {
        "command": "claude-workspaces.cloneRepository",
        "title": "Clone from GitHub",
        "icon": "$(cloud-download)"
      },
      {
        "command": "claude-workspaces.removeRepository",
        "title": "Remove from Extension",
        "icon": "$(close)"
      },
      {
        "command": "claude-workspaces.addWorktree",
        "title": "Create Worktree",
        "icon": "$(add)"
      },
      {
        "command": "claude-workspaces.deleteWorktree",
        "title": "Delete Worktree",
        "icon": "$(trash)"
      },
      {
        "command": "claude-workspaces.mergeWorktree",
        "title": "Merge Branch Into This",
        "icon": "$(git-merge)"
      },
      {
        "command": "claude-workspaces.newChat",
        "title": "New Session",
        "icon": "$(comment-add)"
      },
      {
        "command": "claude-workspaces.openChat",
        "title": "Open Session",
        "icon": "$(terminal)"
      },
      {
        "command": "claude-workspaces.renameChat",
        "title": "Rename Session",
        "icon": "$(edit)"
      },
      {
        "command": "claude-workspaces.deleteChat",
        "title": "Remove from List",
        "icon": "$(close)"
      },
      {
        "command": "claude-workspaces.forkChat",
        "title": "Fork Session",
        "icon": "$(repo-forked)"
      },
      {
        "command": "claude-workspaces.forkChatWithChanges",
        "title": "Fork Session to New Worktree",
        "icon": "$(repo-forked)"
      },
      {
        "command": "claude-workspaces.refreshWorkspaces",
        "title": "Refresh Workspaces",
        "icon": "$(refresh)"
      },
      {
        "command": "claude-workspaces.refreshChanges",
        "title": "Refresh Changes",
        "icon": "$(refresh)"
      },
      {
        "command": "claude-workspaces.openDiff",
        "title": "Open Diff",
        "icon": "$(diff)"
      },
      {
        "command": "claude-workspaces.openInNewWindow",
        "title": "Open in New Window",
        "icon": "$(multiple-windows)"
      },
      {
        "command": "claude-workspaces.switchToWorkspace",
        "title": "Activate Workspace",
        "icon": "$(target)"
      },
      {
        "command": "claude-workspaces.importSessions",
        "title": "Import Existing Sessions",
        "icon": "$(cloud-download)"
      },
      {
        "command": "claude-workspaces.disableAutoSwitch",
        "title": "Disable Auto-Switch Workspace (currently ON)",
        "icon": "$(sync)"
      },
      {
        "command": "claude-workspaces.enableAutoSwitch",
        "title": "Enable Auto-Switch Workspace (currently OFF)",
        "icon": "$(sync-ignored)"
      },
      {
        "command": "claude-workspaces.stageFile",
        "title": "Stage File",
        "icon": "$(add)"
      },
      {
        "command": "claude-workspaces.unstageFile",
        "title": "Unstage File",
        "icon": "$(remove)"
      },
      {
        "command": "claude-workspaces.discardFile",
        "title": "Discard Changes",
        "icon": "$(discard)"
      },
      {
        "command": "claude-workspaces.stageAll",
        "title": "Stage All Changes",
        "icon": "$(add)"
      },
      {
        "command": "claude-workspaces.unstageAll",
        "title": "Unstage All Changes",
        "icon": "$(remove)"
      },
      {
        "command": "claude-workspaces.clearWorktreeSessions",
        "title": "Clear All Sessions",
        "icon": "$(clear-all)"
      },
      {
        "command": "claude-workspaces.copyWorktreePath",
        "title": "Copy Path",
        "icon": "$(copy)"
      },
      {
        "command": "claude-workspaces.openTerminalAtWorktree",
        "title": "Open Terminal",
        "icon": "$(terminal)"
      },
      {
        "command": "claude-workspaces.runQuickAction",
        "title": "Run Quick Action",
        "icon": "$(play)"
      },
      {
        "command": "claude-workspaces.addQuickAction",
        "title": "Add Quick Action",
        "icon": "$(add)"
      },
      {
        "command": "claude-workspaces.runQuickActionFromTree",
        "title": "Run",
        "icon": "$(play)"
      },
      {
        "command": "claude-workspaces.stopQuickAction",
        "title": "Stop",
        "icon": "$(debug-stop)"
      }
    ],
    "configuration": {
      "title": "Claude Workspaces",
      "properties": {
        "claude-workspaces.autoSwitchWorkspaceFolder": {
          "type": "boolean",
          "default": true,
          "description": "Automatically switch VS Code's workspace folder when selecting a worktree or session from a different repository. Disable this to prevent the flickering caused by extension host restart."
        },
        "claude-workspaces.quickActions": {
          "type": "array",
          "default": [
            {
              "name": "Commit",
              "icon": "git-commit",
              "prompt": "Run the /commit-commands:commit slash command to commit the changes.",
              "allowedTools": "Bash(git add:*),Bash(git commit:*),Bash(git status:*),Bash(git diff:*),Bash(git log:*),Read,Glob,Grep"
            },
            {
              "name": "Git Status",
              "icon": "git-branch",
              "command": "git status"
            }
          ],
          "description": "Custom quick actions. Use 'prompt' + 'allowedTools' for Claude headless mode, or 'command' for any shell command.",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "Display name for the action"
              },
              "icon": {
                "type": "string",
                "description": "VS Code icon ID (e.g., git-commit, cloud-upload, terminal)"
              },
              "prompt": {
                "type": "string",
                "description": "The prompt to send to Claude (use with allowedTools)"
              },
              "allowedTools": {
                "type": "string",
                "description": "Comma-separated list of allowed tools for Claude (e.g., Bash(git:*),Read,Glob)"
              },
              "command": {
                "type": "string",
                "description": "Raw shell command to execute (alternative to prompt/allowedTools). Runs cross-platform."
              }
            },
            "required": ["name"]
          }
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "claude-workspaces.addRepository",
          "when": "view == workspacesView",
          "group": "navigation"
        },
        {
          "command": "claude-workspaces.cloneRepository",
          "when": "view == workspacesView",
          "group": "navigation"
        },
        {
          "command": "claude-workspaces.disableAutoSwitch",
          "when": "view == workspacesView && config.claude-workspaces.autoSwitchWorkspaceFolder",
          "group": "navigation"
        },
        {
          "command": "claude-workspaces.enableAutoSwitch",
          "when": "view == workspacesView && !config.claude-workspaces.autoSwitchWorkspaceFolder",
          "group": "navigation"
        },
        {
          "command": "claude-workspaces.refreshWorkspaces",
          "when": "view == workspacesView",
          "group": "navigation"
        },
        {
          "command": "claude-workspaces.refreshChanges",
          "when": "view == changesView",
          "group": "navigation"
        },
        {
          "command": "claude-workspaces.addQuickAction",
          "when": "view == quickActionsView",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "claude-workspaces.addWorktree",
          "when": "view == workspacesView && viewItem == repository",
          "group": "inline@1"
        },
        {
          "command": "claude-workspaces.removeRepository",
          "when": "view == workspacesView && viewItem == repository",
          "group": "inline@2"
        },
        {
          "command": "claude-workspaces.addWorktree",
          "when": "view == workspacesView && viewItem == repository",
          "group": "navigation"
        },
        {
          "command": "claude-workspaces.removeRepository",
          "when": "view == workspacesView && viewItem == repository",
          "group": "3_destructive"
        },
        {
          "command": "claude-workspaces.newChat",
          "when": "view == workspacesView && viewItem == worktree",
          "group": "inline@1"
        },
        {
          "command": "claude-workspaces.openTerminalAtWorktree",
          "when": "view == workspacesView && viewItem == worktree",
          "group": "inline@2"
        },
        {
          "command": "claude-workspaces.switchToWorkspace",
          "when": "view == workspacesView && viewItem == worktree && !config.claude-workspaces.autoSwitchWorkspaceFolder",
          "group": "inline@3"
        },
        {
          "command": "claude-workspaces.switchToWorkspace",
          "when": "view == workspacesView && viewItem == worktree && !config.claude-workspaces.autoSwitchWorkspaceFolder",
          "group": "navigation"
        },
        {
          "command": "claude-workspaces.openInNewWindow",
          "when": "view == workspacesView && viewItem == worktree",
          "group": "navigation"
        },
        {
          "command": "claude-workspaces.openTerminalAtWorktree",
          "when": "view == workspacesView && viewItem == worktree",
          "group": "navigation"
        },
        {
          "command": "claude-workspaces.copyWorktreePath",
          "when": "view == workspacesView && viewItem == worktree",
          "group": "navigation"
        },
        {
          "command": "claude-workspaces.newChat",
          "when": "view == workspacesView && viewItem == worktree",
          "group": "navigation"
        },
        {
          "command": "claude-workspaces.importSessions",
          "when": "view == workspacesView && viewItem == worktree",
          "group": "navigation"
        },
        {
          "command": "claude-workspaces.mergeWorktree",
          "when": "view == workspacesView && viewItem == worktree",
          "group": "2_merge"
        },
        {
          "command": "claude-workspaces.clearWorktreeSessions",
          "when": "view == workspacesView && viewItem == worktree",
          "group": "3_destructive"
        },
        {
          "command": "claude-workspaces.deleteWorktree",
          "when": "view == workspacesView && viewItem == worktree",
          "group": "3_destructive"
        },
        {
          "command": "claude-workspaces.renameChat",
          "when": "view == workspacesView && viewItem == chat",
          "group": "inline@1"
        },
        {
          "command": "claude-workspaces.deleteChat",
          "when": "view == workspacesView && viewItem == chat",
          "group": "inline@2"
        },
        {
          "command": "claude-workspaces.openChat",
          "when": "view == workspacesView && viewItem == chat",
          "group": "navigation"
        },
        {
          "command": "claude-workspaces.renameChat",
          "when": "view == workspacesView && viewItem == chat",
          "group": "navigation"
        },
        {
          "command": "claude-workspaces.forkChat",
          "when": "view == workspacesView && viewItem == chat",
          "group": "2_fork"
        },
        {
          "command": "claude-workspaces.forkChatWithChanges",
          "when": "view == workspacesView && viewItem == chat",
          "group": "2_fork"
        },
        {
          "command": "claude-workspaces.deleteChat",
          "when": "view == workspacesView && viewItem == chat",
          "group": "destructive"
        },
        {
          "command": "claude-workspaces.openDiff",
          "when": "view == workspacesView && viewItem == changedFile",
          "group": "navigation"
        },
        {
          "command": "claude-workspaces.runQuickActionFromTree",
          "when": "view == quickActionsView && viewItem == quickAction",
          "group": "inline"
        },
        {
          "command": "claude-workspaces.stopQuickAction",
          "when": "view == quickActionsView && viewItem == quickActionRunning",
          "group": "inline"
        },
        {
          "command": "claude-workspaces.runQuickActionFromTree",
          "when": "view == quickActionsView && viewItem == quickAction",
          "group": "navigation"
        },
        {
          "command": "claude-workspaces.stopQuickAction",
          "when": "view == quickActionsView && viewItem == quickActionRunning",
          "group": "navigation"
        },
        {
          "command": "claude-workspaces.stageAll",
          "when": "view == changesView && viewItem == unstagedSection",
          "group": "inline"
        },
        {
          "command": "claude-workspaces.unstageAll",
          "when": "view == changesView && viewItem == stagedSection",
          "group": "inline"
        },
        {
          "command": "claude-workspaces.stageFile",
          "when": "view == changesView && viewItem == unstagedFile",
          "group": "inline@1"
        },
        {
          "command": "claude-workspaces.discardFile",
          "when": "view == changesView && viewItem == unstagedFile",
          "group": "inline@2"
        },
        {
          "command": "claude-workspaces.unstageFile",
          "when": "view == changesView && viewItem == stagedFile",
          "group": "inline"
        },
        {
          "command": "claude-workspaces.stageFile",
          "when": "view == changesView && viewItem == unstagedFile",
          "group": "navigation"
        },
        {
          "command": "claude-workspaces.discardFile",
          "when": "view == changesView && viewItem == unstagedFile",
          "group": "destructive"
        },
        {
          "command": "claude-workspaces.unstageFile",
          "when": "view == changesView && viewItem == stagedFile",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.3.0",
    "esbuild": "^0.19.0",
    "typescript": "^5.3.0"
  }
}
