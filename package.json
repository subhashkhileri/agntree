        },
        {
          "command": "agntree.files.copyRelativePath",
          "when": "view == agntree.filesView && (viewItem == file || viewItem == folder)",
          "group": "3_path@2"
        },
        {
          "command": "agntree.files.copy",
          "when": "view == agntree.filesView && (viewItem == file || viewItem == folder)",
          "group": "4_clipboard@1"
        },
        {
          "command": "agntree.files.cut",
          "when": "view == agntree.filesView && (viewItem == file || viewItem == folder)",
          "group": "4_clipboard@2"
        },
        {
          "command": "agntree.files.paste",
          "when": "view == agntree.filesView && (viewItem == folder || viewItem == file) && agntree.hasFileClipboard",
          "group": "4_clipboard@3"
        },
        {
          "command": "agntree.files.newFile",
          "when": "view == agntree.filesView && viewItem == folder",
          "group": "5_create@1"
        },
        {
          "command": "agntree.files.newFolder",
          "when": "view == agntree.filesView && viewItem == folder",
          "group": "5_create@2"
        },
        {
          "command": "agntree.files.rename",
          "when": "view == agntree.filesView && (viewItem == file || viewItem == folder)",
          "group": "6_edit@1"
        },
        {
          "command": "agntree.files.delete",
          "when": "view == agntree.filesView && (viewItem == file || viewItem == folder)",
          "group": "6_edit@2"
        }
      ]
    }
  },
