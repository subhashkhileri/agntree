{
  "name": "agntree",
  "displayName": "Agntree — Claude Code Session & Worktree Manager",
  "description": "Session manager for Claude Code CLI. Resume, fork, search, and organize Claude Code sessions across git worktrees. Built-in changes panel, one-click quick actions, and PR checkout. Works with VS Code and Cursor.",
  "version": "1.2.1",
  "publisher": "subhashkhileri",
  "author": {
    "name": "Subhash Khileri",
    "url": "https://github.com/subhashkhileri"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/subhashkhileri/agntree.git"
  },
  "bugs": {
    "url": "https://github.com/subhashkhileri/agntree/issues"
  },
  "homepage": "https://subhashkhileri.github.io/agntree",
  "qna": "marketplace",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Machine Learning",
    "SCM Providers",
    "Other"
  ],
  "keywords": [
    "claude code",
    "claude",
    "claude code session manager",
    "claude code worktree",
    "claude session",
    "anthropic",
    "ai coding agent",
    "session manager",
    "git worktree",
    "worktree manager",
    "cursor",
    "ai coding",
    "copilot",
    "cline",
    "aider",
    "windsurf",
    "session forking",
    "multi-repo",
    "developer tools",
    "ai assistant"
  ],
  "icon": "resources/icons/agntree.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agntree",
          "title": "Agntree",
          "icon": "resources/icons/agntree.svg"
        }
      ]
    },
    "views": {
      "agntree": [
        {
          "id": "agntree.workspacesView",
          "name": "Workspaces",
          "size": 4
        },
        {
          "id": "agntree.changesView",
          "name": "Changes",
          "size": 2
        },
        {
          "id": "agntree.filesView",
          "name": "All Files",
          "size": 3
        },
        {
          "id": "agntree.quickActionsView",
          "name": "Quick Actions",
          "size": 1,
          "visibility": "collapsed"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "agntree.workspacesView",
        "contents": "Start managing your Claude Code sessions across repositories.\n\n[Add Local Repository](command:agntree.addRepository)\n[Clone from GitHub](command:agntree.cloneRepository)\n\nAdd an existing git repository or clone one from GitHub to get started."
      },
      {
        "view": "agntree.changesView",
        "contents": "Select a worktree or session to view uncommitted changes.\n\nClick the diff icon on any file to view side-by-side comparison."
      },
      {
        "view": "agntree.filesView",
        "contents": "Select a worktree or session to browse its files."
      },
      {
        "view": "agntree.quickActionsView",
        "contents": "Run Claude prompts or shell commands.\n\n[Add Quick Action](command:agntree.addQuickAction)\n\nConfigure actions in Settings → agntree.quickActions"
      }
    ],
