{
  "name": "claude-workspaces",
  "displayName": "Claude Workspaces",
  "description": "Manage Claude Code sessions across repositories and worktrees",
  "version": "0.1.0",
  "publisher": "claude-workspaces",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claude-workspaces",
          "title": "Claude Workspaces",
          "icon": "resources/icons/claude.svg"
        }
      ]
    },
    "views": {
      "claude-workspaces": [
        {
          "id": "workspacesView",
          "name": "Workspaces"
        },
        {
          "id": "changesView",
          "name": "Changes"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "workspacesView",
        "contents": "Start managing your Claude Code sessions across repositories.\n\n[Add Repository](command:claude-workspaces.addRepository)\n\nAdd a git repository to create and manage Claude Code chat sessions organized by worktrees."
      },
      {
        "view": "changesView",
        "contents": "Select a worktree or chat to view uncommitted changes.\n\nClick the diff icon on any file to view side-by-side comparison."
      }
    ],
    "commands": [
      {
        "command": "claude-workspaces.addRepository",
        "title": "Add Repository",
        "icon": "$(add)"
      },
      {
        "command": "claude-workspaces.removeRepository",
        "title": "Remove from Extension",
        "icon": "$(close)"
      },
      {
        "command": "claude-workspaces.addWorktree",
        "title": "Create Worktree",
        "icon": "$(add)"
      },
      {
        "command": "claude-workspaces.deleteWorktree",
        "title": "Delete Worktree",
        "icon": "$(trash)"
      },
      {
        "command": "claude-workspaces.mergeWorktree",
        "title": "Merge Branch Into This",
        "icon": "$(git-merge)"
      },
      {
        "command": "claude-workspaces.newChat",
        "title": "New Chat",
        "icon": "$(comment-add)"
      },
      {
        "command": "claude-workspaces.openChat",
        "title": "Open Chat",
        "icon": "$(terminal)"
      },
      {
        "command": "claude-workspaces.renameChat",
        "title": "Rename Chat",
        "icon": "$(edit)"
      },
      {
        "command": "claude-workspaces.deleteChat",
        "title": "Remove from List",
        "icon": "$(close)"
      },
      {
        "command": "claude-workspaces.forkChat",
        "title": "Fork Chat",
        "icon": "$(repo-forked)"
      },
      {
        "command": "claude-workspaces.forkChatWithChanges",
        "title": "Fork Chat to New Worktree",
        "icon": "$(repo-forked)"
      },
      {
        "command": "claude-workspaces.refreshWorkspaces",
        "title": "Refresh Workspaces",
        "icon": "$(refresh)"
      },
      {
        "command": "claude-workspaces.refreshChanges",
        "title": "Refresh Changes",
        "icon": "$(refresh)"
      },
      {
        "command": "claude-workspaces.openDiff",
        "title": "Open Diff",
        "icon": "$(diff)"
      },
      {
        "command": "claude-workspaces.openInNewWindow",
        "title": "Open in New Window",
        "icon": "$(multiple-windows)"
      },
      {
        "command": "claude-workspaces.switchToWorkspace",
        "title": "Switch to Workspace",
        "icon": "$(folder-opened)"
      },
      {
        "command": "claude-workspaces.importSessions",
        "title": "Import Existing Sessions",
        "icon": "$(cloud-download)"
      },
      {
        "command": "claude-workspaces.disableAutoSwitch",
        "title": "Disable Auto-Switch Workspace (currently ON)",
        "icon": "$(sync)"
      },
      {
        "command": "claude-workspaces.enableAutoSwitch",
        "title": "Enable Auto-Switch Workspace (currently OFF)",
        "icon": "$(sync-ignored)"
      },
      {
        "command": "claude-workspaces.stageFile",
        "title": "Stage File",
        "icon": "$(add)"
      },
      {
        "command": "claude-workspaces.unstageFile",
        "title": "Unstage File",
        "icon": "$(remove)"
      },
      {
        "command": "claude-workspaces.discardFile",
        "title": "Discard Changes",
        "icon": "$(discard)"
      },
      {
        "command": "claude-workspaces.stageAll",
        "title": "Stage All Changes",
        "icon": "$(add)"
      },
      {
        "command": "claude-workspaces.unstageAll",
        "title": "Unstage All Changes",
        "icon": "$(remove)"
      }
    ],
    "configuration": {
      "title": "Claude Workspaces",
      "properties": {
        "claude-workspaces.autoSwitchWorkspaceFolder": {
          "type": "boolean",
          "default": true,
          "description": "Automatically switch VS Code's workspace folder when selecting a worktree or chat from a different repository. Disable this to prevent the flickering caused by extension host restart."
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "claude-workspaces.addRepository",
          "when": "view == workspacesView",
          "group": "navigation"
        },
        {
          "command": "claude-workspaces.disableAutoSwitch",
          "when": "view == workspacesView && config.claude-workspaces.autoSwitchWorkspaceFolder",
          "group": "navigation"
        },
        {
          "command": "claude-workspaces.enableAutoSwitch",
          "when": "view == workspacesView && !config.claude-workspaces.autoSwitchWorkspaceFolder",
          "group": "navigation"
        },
        {
          "command": "claude-workspaces.refreshWorkspaces",
          "when": "view == workspacesView",
          "group": "navigation"
        },
        {
          "command": "claude-workspaces.refreshChanges",
          "when": "view == changesView",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "claude-workspaces.addWorktree",
          "when": "view == workspacesView && viewItem == repository",
          "group": "inline@1"
        },
        {
          "command": "claude-workspaces.removeRepository",
          "when": "view == workspacesView && viewItem == repository",
          "group": "inline@2"
        },
        {
          "command": "claude-workspaces.addWorktree",
          "when": "view == workspacesView && viewItem == repository",
          "group": "navigation"
        },
        {
          "command": "claude-workspaces.removeRepository",
          "when": "view == workspacesView && viewItem == repository",
          "group": "3_destructive"
        },
        {
          "command": "claude-workspaces.newChat",
          "when": "view == workspacesView && viewItem == worktree",
          "group": "inline@1"
        },
        {
          "command": "claude-workspaces.switchToWorkspace",
          "when": "view == workspacesView && viewItem == worktree && !config.claude-workspaces.autoSwitchWorkspaceFolder",
          "group": "inline@2"
        },
        {
          "command": "claude-workspaces.switchToWorkspace",
          "when": "view == workspacesView && viewItem == worktree && !config.claude-workspaces.autoSwitchWorkspaceFolder",
          "group": "navigation"
        },
        {
          "command": "claude-workspaces.openInNewWindow",
          "when": "view == workspacesView && viewItem == worktree",
          "group": "navigation"
        },
        {
          "command": "claude-workspaces.newChat",
          "when": "view == workspacesView && viewItem == worktree",
          "group": "navigation"
        },
        {
          "command": "claude-workspaces.importSessions",
          "when": "view == workspacesView && viewItem == worktree",
          "group": "navigation"
        },
        {
          "command": "claude-workspaces.mergeWorktree",
          "when": "view == workspacesView && viewItem == worktree",
          "group": "2_merge"
        },
        {
          "command": "claude-workspaces.deleteWorktree",
          "when": "view == workspacesView && viewItem == worktree",
          "group": "3_destructive"
        },
        {
          "command": "claude-workspaces.renameChat",
          "when": "view == workspacesView && viewItem == chat",
          "group": "inline@1"
        },
        {
          "command": "claude-workspaces.deleteChat",
          "when": "view == workspacesView && viewItem == chat",
          "group": "inline@2"
        },
        {
          "command": "claude-workspaces.openChat",
          "when": "view == workspacesView && viewItem == chat",
          "group": "navigation"
        },
        {
          "command": "claude-workspaces.renameChat",
          "when": "view == workspacesView && viewItem == chat",
          "group": "navigation"
        },
        {
          "command": "claude-workspaces.forkChat",
          "when": "view == workspacesView && viewItem == chat",
          "group": "2_fork"
        },
        {
          "command": "claude-workspaces.forkChatWithChanges",
          "when": "view == workspacesView && viewItem == chat",
          "group": "2_fork"
        },
        {
          "command": "claude-workspaces.deleteChat",
          "when": "view == workspacesView && viewItem == chat",
          "group": "destructive"
        },
        {
          "command": "claude-workspaces.openDiff",
          "when": "view == workspacesView && viewItem == changedFile",
          "group": "navigation"
        },
        {
          "command": "claude-workspaces.stageAll",
          "when": "view == changesView && viewItem == unstagedSection",
          "group": "inline"
        },
        {
          "command": "claude-workspaces.unstageAll",
          "when": "view == changesView && viewItem == stagedSection",
          "group": "inline"
        },
        {
          "command": "claude-workspaces.stageFile",
          "when": "view == changesView && viewItem == unstagedFile",
          "group": "inline@1"
        },
        {
          "command": "claude-workspaces.discardFile",
          "when": "view == changesView && viewItem == unstagedFile",
          "group": "inline@2"
        },
        {
          "command": "claude-workspaces.unstageFile",
          "when": "view == changesView && viewItem == stagedFile",
          "group": "inline"
        },
        {
          "command": "claude-workspaces.stageFile",
          "when": "view == changesView && viewItem == unstagedFile",
          "group": "navigation"
        },
        {
          "command": "claude-workspaces.discardFile",
          "when": "view == changesView && viewItem == unstagedFile",
          "group": "destructive"
        },
        {
          "command": "claude-workspaces.unstageFile",
          "when": "view == changesView && viewItem == stagedFile",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.3.0",
    "esbuild": "^0.19.0",
    "typescript": "^5.3.0"
  }
}
