{
  "name": "agntree",
  "displayName": "Agntree - Claude Code Session Manager",
  "description": "Manage Claude Code CLI sessions across multiple git repositories and worktrees. Fork sessions, track changes, run quick actions, and seamlessly switch between AI coding contexts.",
  "version": "0.1.0",
  "publisher": "subhashkhileri",
  "author": {
    "name": "Subhash Khileri",
    "url": "https://github.com/subhashkhileri"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/subhashkhileri/agntree.git"
  },
  "bugs": {
    "url": "https://github.com/subhashkhileri/agntree/issues"
  },
  "homepage": "https://github.com/subhashkhileri/agntree#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Machine Learning",
    "Other"
  ],
  "keywords": [
    "claude",
    "claude code",
    "ai",
    "ai coding",
    "anthropic",
    "git worktree",
    "worktree",
    "session manager",
    "ai assistant",
    "code assistant",
    "llm",
    "terminal",
    "git",
    "productivity"
  ],
  "icon": "resources/icons/agntree.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agntree",
          "title": "Agntree",
          "icon": "resources/icons/agntree.svg"
        }
      ]
    },
    "views": {
      "agntree": [
        {
          "id": "agntree.workspacesView",
          "name": "Workspaces"
        },
        {
          "id": "agntree.changesView",
          "name": "Changes"
        },
        {
          "id": "agntree.quickActionsView",
          "name": "Quick Actions"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "agntree.workspacesView",
        "contents": "Start managing your Claude Code sessions across repositories.\n\n[Add Local Repository](command:agntree.addRepository)\n[Clone from GitHub](command:agntree.cloneRepository)\n\nAdd an existing git repository or clone one from GitHub to get started."
      },
      {
        "view": "agntree.changesView",
        "contents": "Select a worktree or session to view uncommitted changes.\n\nClick the diff icon on any file to view side-by-side comparison."
      },
      {
        "view": "agntree.quickActionsView",
        "contents": "Run Claude prompts or shell commands.\n\n[Add Quick Action](command:agntree.addQuickAction)\n\nConfigure actions in Settings → agntree.quickActions"
      }
    ],
    "commands": [
      {
        "command": "agntree.addRepository",
        "title": "Add Local Repository",
        "icon": "$(folder)"
      },
      {
        "command": "agntree.cloneRepository",
        "title": "Clone from GitHub",
        "icon": "$(cloud-download)"
      },
      {
        "command": "agntree.removeRepository",
        "title": "Remove from Extension",
        "icon": "$(close)"
      },
      {
        "command": "agntree.addWorktree",
        "title": "Create Worktree",
        "icon": "$(add)"
      },
      {
        "command": "agntree.deleteWorktree",
        "title": "Delete Worktree",
        "icon": "$(trash)"
      },
      {
        "command": "agntree.mergeWorktree",
        "title": "Merge Branch Into This",
        "icon": "$(git-merge)"
      },
      {
        "command": "agntree.newChat",
        "title": "New Session",
        "icon": "$(comment-add)"
      },
      {
        "command": "agntree.openChat",
        "title": "Open Session",
        "icon": "$(terminal)"
      },
      {
        "command": "agntree.renameChat",
        "title": "Rename Session",
        "icon": "$(edit)"
      },
      {
        "command": "agntree.deleteChat",
        "title": "Remove from List",
        "icon": "$(close)"
      },
      {
        "command": "agntree.forkChat",
        "title": "Fork Session",
        "icon": "$(repo-forked)"
      },
      {
        "command": "agntree.forkChatWithChanges",
        "title": "Fork Session to New Worktree",
        "icon": "$(repo-forked)"
      },
      {
        "command": "agntree.refreshWorkspaces",
        "title": "Refresh Workspaces",
        "icon": "$(refresh)"
      },
      {
        "command": "agntree.refreshChanges",
        "title": "Refresh Changes",
        "icon": "$(refresh)"
      },
      {
        "command": "agntree.openDiff",
        "title": "Open Diff",
        "icon": "$(diff)"
      },
      {
        "command": "agntree.openInNewWindow",
        "title": "Open in New Window",
        "icon": "$(multiple-windows)"
      },
      {
        "command": "agntree.switchToWorkspace",
        "title": "Activate Workspace",
        "icon": "$(target)"
      },
      {
        "command": "agntree.importSessions",
        "title": "Import Existing Sessions",
        "icon": "$(cloud-download)"
      },
      {
        "command": "agntree.disableAutoSwitch",
        "title": "Disable Auto-Switch Workspace (currently ON)",
        "icon": "$(sync)"
      },
      {
        "command": "agntree.enableAutoSwitch",
        "title": "Enable Auto-Switch Workspace (currently OFF)",
        "icon": "$(sync-ignored)"
      },
      {
        "command": "agntree.stageFile",
        "title": "Stage File",
        "icon": "$(add)"
      },
      {
        "command": "agntree.unstageFile",
        "title": "Unstage File",
        "icon": "$(remove)"
      },
      {
        "command": "agntree.discardFile",
        "title": "Discard Changes",
        "icon": "$(discard)"
      },
      {
        "command": "agntree.stageAll",
        "title": "Stage All Changes",
        "icon": "$(add)"
      },
      {
        "command": "agntree.unstageAll",
        "title": "Unstage All Changes",
        "icon": "$(remove)"
      },
      {
        "command": "agntree.clearWorktreeSessions",
        "title": "Clear All Sessions",
        "icon": "$(clear-all)"
      },
      {
        "command": "agntree.copyWorktreePath",
        "title": "Copy Path",
        "icon": "$(copy)"
      },
      {
        "command": "agntree.openTerminalAtWorktree",
        "title": "Open Terminal",
        "icon": "$(terminal)"
      },
      {
        "command": "agntree.runQuickAction",
        "title": "Run Quick Action",
        "icon": "$(play)"
      },
      {
        "command": "agntree.addQuickAction",
        "title": "Add Quick Action",
        "icon": "$(add)"
      },
      {
        "command": "agntree.runQuickActionFromTree",
        "title": "Run",
        "icon": "$(play)"
      },
      {
        "command": "agntree.stopQuickAction",
        "title": "Stop",
        "icon": "$(debug-stop)"
      },
      {
        "command": "agntree.openPRInBrowser",
        "title": "Open PR in Browser",
        "icon": "$(link-external)"
      }
    ],
    "configuration": {
      "title": "Agntree",
      "properties": {
        "agntree.autoSwitchWorkspaceFolder": {
          "type": "boolean",
          "default": false,
          "description": "Automatically switch VS Code's workspace folder when selecting a worktree or session from a different repository. Disable this to prevent the flickering caused by extension host restart."
        },
        "agntree.quickActions": {
          "type": "array",
          "default": [
            {
              "name": "Commit",
              "icon": "git-commit",
              "prompt": "Run the /commit-commands:commit slash command to commit the changes.",
              "allowedTools": "Bash(git add:*),Bash(git commit:*),Bash(git status:*),Bash(git diff:*),Bash(git log:*),Read,Glob,Grep"
            },
            {
              "name": "Git Status",
              "icon": "git-branch",
              "command": "git status"
            }
          ],
          "description": "Custom quick actions. Use 'prompt' + 'allowedTools' for Claude headless mode, or 'command' for any shell command.",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "Display name for the action"
              },
              "icon": {
                "type": "string",
                "description": "VS Code icon ID (e.g., git-commit, cloud-upload, terminal)"
              },
              "prompt": {
                "type": "string",
                "description": "The prompt to send to Claude (use with allowedTools)"
              },
              "allowedTools": {
                "type": "string",
                "description": "Comma-separated list of allowed tools for Claude (e.g., Bash(git:*),Read,Glob)"
              },
              "command": {
                "type": "string",
                "description": "Raw shell command to execute (alternative to prompt/allowedTools). Runs cross-platform."
              }
            },
            "required": ["name"]
          }
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "agntree.addRepository",
          "when": "view == agntree.workspacesView",
          "group": "navigation"
        },
        {
          "command": "agntree.cloneRepository",
          "when": "view == agntree.workspacesView",
          "group": "navigation"
        },
        {
          "command": "agntree.disableAutoSwitch",
          "when": "view == agntree.workspacesView && config.agntree.autoSwitchWorkspaceFolder",
          "group": "navigation"
        },
        {
          "command": "agntree.enableAutoSwitch",
          "when": "view == agntree.workspacesView && !config.agntree.autoSwitchWorkspaceFolder",
          "group": "navigation"
        },
        {
          "command": "agntree.refreshWorkspaces",
          "when": "view == agntree.workspacesView",
          "group": "navigation"
        },
        {
          "command": "agntree.refreshChanges",
          "when": "view == agntree.changesView",
          "group": "navigation"
        },
        {
          "command": "agntree.addQuickAction",
          "when": "view == agntree.quickActionsView",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "agntree.addWorktree",
          "when": "view == agntree.workspacesView && viewItem == repository",
          "group": "inline@1"
        },
        {
          "command": "agntree.removeRepository",
          "when": "view == agntree.workspacesView && viewItem == repository",
          "group": "inline@2"
        },
        {
          "command": "agntree.addWorktree",
          "when": "view == agntree.workspacesView && viewItem == repository",
          "group": "navigation"
        },
        {
          "command": "agntree.removeRepository",
          "when": "view == agntree.workspacesView && viewItem == repository",
          "group": "3_destructive"
        },
        {
          "command": "agntree.newChat",
          "when": "view == agntree.workspacesView && viewItem == worktree",
          "group": "inline@1"
        },
        {
          "command": "agntree.openTerminalAtWorktree",
          "when": "view == agntree.workspacesView && viewItem == worktree",
          "group": "inline@2"
        },
        {
          "command": "agntree.openInNewWindow",
          "when": "view == agntree.workspacesView && viewItem == worktree",
          "group": "inline@3"
        },
        {
          "command": "agntree.switchToWorkspace",
          "when": "view == agntree.workspacesView && viewItem == worktree && !config.agntree.autoSwitchWorkspaceFolder",
          "group": "inline@4"
        },
        {
          "command": "agntree.deleteWorktree",
          "when": "view == agntree.workspacesView && viewItem == worktree",
          "group": "inline@5"
        },
        {
          "command": "agntree.switchToWorkspace",
          "when": "view == agntree.workspacesView && viewItem == worktree && !config.agntree.autoSwitchWorkspaceFolder",
          "group": "navigation"
        },
        {
          "command": "agntree.openInNewWindow",
          "when": "view == agntree.workspacesView && viewItem == worktree",
          "group": "navigation"
        },
        {
          "command": "agntree.openTerminalAtWorktree",
          "when": "view == agntree.workspacesView && viewItem == worktree",
          "group": "navigation"
        },
        {
          "command": "agntree.copyWorktreePath",
          "when": "view == agntree.workspacesView && viewItem == worktree",
          "group": "navigation"
        },
        {
          "command": "agntree.newChat",
          "when": "view == agntree.workspacesView && viewItem == worktree",
          "group": "navigation"
        },
        {
          "command": "agntree.importSessions",
          "when": "view == agntree.workspacesView && viewItem == worktree",
          "group": "navigation"
        },
        {
          "command": "agntree.openPRInBrowser",
          "when": "view == agntree.workspacesView && viewItem == worktree",
          "group": "navigation"
        },
        {
          "command": "agntree.mergeWorktree",
          "when": "view == agntree.workspacesView && viewItem == worktree",
          "group": "2_merge"
        },
        {
          "command": "agntree.clearWorktreeSessions",
          "when": "view == agntree.workspacesView && viewItem == worktree",
          "group": "3_destructive"
        },
        {
          "command": "agntree.deleteWorktree",
          "when": "view == agntree.workspacesView && viewItem == worktree",
          "group": "3_destructive"
        },
        {
          "command": "agntree.renameChat",
          "when": "view == agntree.workspacesView && viewItem == chat",
          "group": "inline@1"
        },
        {
          "command": "agntree.deleteChat",
          "when": "view == agntree.workspacesView && viewItem == chat",
          "group": "inline@2"
        },
        {
          "command": "agntree.openChat",
          "when": "view == agntree.workspacesView && viewItem == chat",
          "group": "navigation"
        },
        {
          "command": "agntree.renameChat",
          "when": "view == agntree.workspacesView && viewItem == chat",
          "group": "navigation"
        },
        {
          "command": "agntree.forkChat",
          "when": "view == agntree.workspacesView && viewItem == chat",
          "group": "2_fork"
        },
        {
          "command": "agntree.forkChatWithChanges",
          "when": "view == agntree.workspacesView && viewItem == chat",
          "group": "2_fork"
        },
        {
          "command": "agntree.deleteChat",
          "when": "view == agntree.workspacesView && viewItem == chat",
          "group": "destructive"
        },
        {
          "command": "agntree.openDiff",
          "when": "view == agntree.workspacesView && viewItem == changedFile",
          "group": "navigation"
        },
        {
          "command": "agntree.runQuickActionFromTree",
          "when": "view == agntree.quickActionsView && viewItem == quickAction",
          "group": "inline"
        },
        {
          "command": "agntree.stopQuickAction",
          "when": "view == agntree.quickActionsView && viewItem == quickActionRunning",
          "group": "inline"
        },
        {
          "command": "agntree.runQuickActionFromTree",
          "when": "view == agntree.quickActionsView && viewItem == quickAction",
          "group": "navigation"
        },
        {
          "command": "agntree.stopQuickAction",
          "when": "view == agntree.quickActionsView && viewItem == quickActionRunning",
          "group": "navigation"
        },
        {
          "command": "agntree.stageAll",
          "when": "view == agntree.changesView && viewItem == unstagedSection",
          "group": "inline"
        },
        {
          "command": "agntree.unstageAll",
          "when": "view == agntree.changesView && viewItem == stagedSection",
          "group": "inline"
        },
        {
          "command": "agntree.stageFile",
          "when": "view == agntree.changesView && viewItem == unstagedFile",
          "group": "inline@1"
        },
        {
          "command": "agntree.discardFile",
          "when": "view == agntree.changesView && viewItem == unstagedFile",
          "group": "inline@2"
        },
        {
          "command": "agntree.unstageFile",
          "when": "view == agntree.changesView && viewItem == stagedFile",
          "group": "inline"
        },
        {
          "command": "agntree.stageFile",
          "when": "view == agntree.changesView && viewItem == unstagedFile",
          "group": "navigation"
        },
        {
          "command": "agntree.discardFile",
          "when": "view == agntree.changesView && viewItem == unstagedFile",
          "group": "destructive"
        },
        {
          "command": "agntree.unstageFile",
          "when": "view == agntree.changesView && viewItem == stagedFile",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.3.0",
    "esbuild": "^0.19.0",
    "typescript": "^5.3.0"
  }
}
